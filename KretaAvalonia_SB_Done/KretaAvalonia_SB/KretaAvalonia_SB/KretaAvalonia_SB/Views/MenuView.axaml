<?xml version="1.0" encoding="UTF-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:KretaAvalonia_SB.ViewModels"
             mc:Ignorable="d"
             x:Class="KretaAvalonia_SB.Views.MenuView"
             x:DataType="vm:MenuViewModel"
              Height="880"
             MinHeight="880"
             Width="480"
             MinWidth="480"
             >
    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable"/>
            <Setter Property="Padding" Value="0,10"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E88E5"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="Button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#0D47A1"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#7DD6F8" Offset="0"/>
                <GradientStop Color="#42A5F5" Offset="0.5"/>
                <GradientStop Color="#1E88E5" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>


       

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Fejléc -->
        <Border Grid.Row="0" Background="#1565C0" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>


                    <Border Grid.Column="0"
                        BorderBrush="White"
                        BorderThickness="1.5"
                        CornerRadius="6"
                        Padding="12,4">
                    <TextBlock Text="KRÉTA"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               FontFamily="Segoe UI Variable"
                               VerticalAlignment="Center"/>
                </Border>
                <Button Grid.Column="2"
                        Content="Kijelentkezés"
                        Command="{Binding LogOutCommand}"
                        HorizontalAlignment="Right"
                        Padding="14,6"
                        Background="#0D47A1"/>
            </Grid>
        </Border>

    
        <Border Grid.Row="1"
                MaxWidth="420"
                Width="420"
                Padding="40,30"
                Margin="0,40"
                Background="#FFFFFF"
                CornerRadius="10"
                BoxShadow="0 4 16 0 #55000000"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">


            <StackPanel Spacing="12">
                <TextBlock Text="MENU"
                           FontSize="30"
                           FontWeight="Bold"
                           FontFamily="Segoe UI Variable"
                           Foreground="#1565C0"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <Button Content="Adataim" FontSize="20" FontWeight="Bold" FontFamily="Segoe UI Variable" Command="{Binding DataCommand}"/>
                <Button Content="Jegyeim" FontSize="20"  FontWeight="Bold" FontFamily="Segoe UI Variable" Command="{Binding GradeCommand}"/>
                <Button Content="Üzenetek" FontSize="20"  FontWeight="Bold" FontFamily="Segoe UI Variable" Command="{Binding MessageCommand}"/>
                <Button Content="Órarend" FontSize="20" FontWeight="Bold" FontFamily="Segoe UI Variable" Command="{Binding TimeTableCommand}"/>
            </StackPanel>
        </Border>

    </Grid>


</UserControl>
