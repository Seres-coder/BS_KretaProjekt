<?xml version="1.0" encoding="UTF-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:KretaAvalonia_SB.ViewModels"
             mc:Ignorable="d"
             x:Class="KretaAvalonia_SB.Views.DataView"
             x:DataType="vm:DataViewModel"
             Height="880"
             MinHeight="880"
             Width="480"
             MinWidth="480">

    <!-- STYLES -->
    <UserControl.Styles>

        <!-- Normál gombok -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable"/>
            <Setter Property="Padding" Value="14,6"/>
        </Style>

        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E88E5"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.primary:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#0D47A1"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>

    </UserControl.Styles>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#7DD6F8" Offset="0"/>
                <GradientStop Color="#42A5F5" Offset="0.5"/>
                <GradientStop Color="#1E88E5" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FEJLÉC -->
        <Border Grid.Row="0" Background="#1565C0" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                
                <Button Grid.Column="0"
                        Command="{Binding BackCommand}"
                        Background="Transparent"
                        BorderBrush="White"
                        BorderThickness="1.5"
                        CornerRadius="6"
                        Padding="8,2">
                    <TextBlock Text="KRÉTA"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               FontFamily="Segoe UI Variable"
                               VerticalAlignment="Center"/>
                </Button>

                <!-- Cím -->
                <TextBlock Grid.Column="2"
                           Text="Adataim"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           FontFamily="Segoe UI Variable"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

            </Grid>
        </Border>

        <!-- TARTALOM -->
        <Border Grid.Row="1"
            MaxWidth="420"
            MinWidth="400"
            Padding="16,12"
            Margin="0,20"
            Background="#FFFFFF"
            CornerRadius="10"
            BoxShadow="0 4 16 0 #55000000"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <ScrollViewer>
                <StackPanel Spacing="16">

                    <StackPanel Spacing="2">
                        <TextBlock Text="Név"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI Variable"
                                   Foreground="#1565C0"/>
                        <TextBlock Text="{Binding StudentData?.diak_nev}"
                                   FontFamily="Segoe UI Variable"
                                   Foreground="#333333"/>
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock Text="Lakcím"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI Variable"
                                   Foreground="#1565C0"/>
                        <TextBlock Text="{Binding StudentData?.lakcim}"
                                   FontFamily="Segoe UI Variable"
                                   Foreground="#333333"/>
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock Text="Szülő neve"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI Variable"
                                   Foreground="#1565C0"/>
                        <TextBlock Text="{Binding StudentData?.szuloneve}"
                                   FontFamily="Segoe UI Variable"
                                   Foreground="#333333"/>
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock Text="Email cím"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI Variable"
                                   Foreground="#1565C0"/>
                        <TextBlock Text="{Binding StudentData?.emailcim}"
                                   FontFamily="Segoe UI Variable"
                                   Foreground="#333333"/>
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock Text="Születési dátum"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI Variable"
                                   Foreground="#1565C0"/>
                        <TextBlock Text="{Binding StudentData?.szuletesi_datum}"
                                   FontFamily="Segoe UI Variable"
                                   Foreground="#333333"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>